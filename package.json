{
  "packageManager": "pnpm@10.16.1",
  "repository": {
    "url": "https://github.com/muni-town/roomy"
  },
  "engines": {
    "node": "^22.15.0"
  },
  "scripts": {
    "build-api-docs": "turbo build-api-docs",
    "build-web-app": "turbo build-web-app",
    "lint-staged": "turbo lint-staged",
    "publish-packages": "turbo build && beachball publish -m 'chore: publish packages.'",
    "prepare": "node ./.husky/install.mjs",
    "dev": "turbo run dev --filter=roomy.chat",
    "dev:bridge": "turbo run dev --filter=discord-bridge",
    "dev:all": "turbo dev",
    "dev:local": "docker compose up -d && pnpm setup:local-dev && cd packages/app && pnpm dev",
    "setup:local-dev": "cd packages/app && tsx scripts/setup-local-dev.ts",
    "setup:local-dev:reset": "docker compose down -v && docker compose up -d && pnpm setup:local-dev",
    "pds:logs": "docker compose logs pds -f"
  },
  "devDependencies": {
    "@repo/tsconfig": "workspace:*",
    "beachball": "^2.54.0",
    "clsx": "^2.1.1",
    "flexsearch": "^0.8.205",
    "husky": "^9.1.7",
    "pkgroll": "^2.13.1",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tsx": "^4.20.3",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@muni-town/leaf-client": "link:../leaf/clients/typescript",
    "date-fns": "^4.1.0"
  }
}
