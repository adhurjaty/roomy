# for white labeled roomy version, set PUBLIC_HIDE_SMALL_SIDEBAR to true
# and set PUBLIC_DEFAULT_SPACE_ID to the space you want to open automatically
# optionally set PUBLIC_SHOW_BRANDING to true to show "powered by roomy.space" in sidebar
PUBLIC_HIDE_SMALL_SIDEBAR=
PUBLIC_DEFAULT_SPACE_ID=
PUBLIC_SHOW_BRANDING=
PUBLIC_DISCORD_BRIDGE=http://localhost:3301
PUBLIC_PDS="https://roomy.chat"
PUBLIC_PDS_HANDLE_SUFFIX=".roomy.chat"
PUBLIC_PDS_INVITE_CODE="sort-of-secret"

# Local Development (uncomment to use local PDS)
# Requires running: docker compose up -d && pnpm setup:local-dev
# Login with: alice.test / password-alice (or bob, carol, dave, eve)
# PUBLIC_PDS="http://localhost:2583"
# PUBLIC_PDS_HANDLE_SUFFIX=".test"
# VITE_HANDLE_RESOLVER=http://localhost:2583
# VITE_PLC_DIRECTORY=http://localhost:3001
# VITE_LEAF_URL=http://localhost:5530

# The default for dev, using our hosted dev leaf server
# ( data on this server is not reliable and may be deleted )
VITE_LEAF_URL=https://leaf-dev.muni.town
VITE_STREAM_NSID=space.roomy.space.personal.dev
VITE_STREAM_HANDLE_NSID=space.roomy.profileSpace.dev

# Prod settings
# VITE_LEAF_URL=https://leaf.muni.town
# VITE_STREAM_NSID=space.roomy.stream
# VITE_STREAM_HANDLE_NSID=space.roomy.space.handle

# Use this if you are running the Leaf server locally
#VITE_LEAF_URL=http://localhost:5530/
#VITE_STREAM_NSID=space.roomy.space.personal.dev.local
#VITE_STREAM_HANDLE_NSID=space.roomy.space.handle.dev.local

# Some browsers don't permit inspecting SharedWorker logs directly, so we can forward them
SHARED_WORKER_LOG_FORWARDING=false


# ATProto App Password for automated testing authentication
VITE_TESTING_APP_PASSWORD=
VITE_TESTING_HANDLE=

# Configure local Faro. Remember to run `docker compose up -d` in the repo root to run Faro.
VITE_FARO_ENDPOINT="http://localhost:12345/collect"

# Min level to send to Faro
VITE_LOG_LEVEL=